apiVersion: apps/v1
kind: Deployment
metadata:
  name: metrics-server
  namespace: kube-system
  labels:
    k8s-app: metrics-server
spec:
  replicas: {{ k8s_metrics_replicas }}
  selector:
    matchLabels:
      k8s-app: metrics-server
  template:
    metadata:
      labels:
        k8s-app: metrics-server
    spec:
      serviceAccountName: metrics-server
      priorityClassName: system-cluster-critical
      tolerations:
        - key: CriticalAddonsOnly
          operator: Exists
        - key: node-role.kubernetes.io/control-plane
          operator: Exists
          effect: NoSchedule
        - key: node-role.kubernetes.io/master
          operator: Exists
          effect: NoSchedule
{% if k8s_metrics_tolerations | length > 0 %}
{% for toleration in k8s_metrics_tolerations %}
        - key: {{ toleration.key | default('') }}
          operator: {{ toleration.operator | default('Equal') }}
{% if toleration.value is defined %}
          value: {{ toleration.value }}
{% endif %}
{% if toleration.effect is defined %}
          effect: {{ toleration.effect }}
{% endif %}
{% endfor %}
{% endif %}
{% if k8s_metrics_node_selector | length > 0 %}
      nodeSelector:
{% for key, value in k8s_metrics_node_selector.items() %}
        {{ key }}: {{ value }}
{% endfor %}
{% endif %}
      containers:
        - name: metrics-server
          image: registry.k8s.io/metrics-server/metrics-server:v{{ k8s_metrics_version }}
          imagePullPolicy: IfNotPresent
          args:
            - --cert-dir=/tmp
            - --secure-port=10250
            - --kubelet-preferred-address-types={{ k8s_metrics_kubelet_preferred_address_types }}
            - --kubelet-use-node-status-port
            - --metric-resolution={{ k8s_metrics_resolution }}
            - --kubelet-insecure-tls={{ k8s_metrics_kubelet_insecure_tls | lower }}
            - --metric-duration={{ k8s_metrics_metric_duration }}
            - --enable-hpa={{ k8s_metrics_enable_autoscaling | lower }}
            - --enable-vpa={{ k8s_metrics_enable_autoscaling | lower }}
          ports:
            - name: https
              containerPort: 10250
              protocol: TCP
          resources:
            limits:
              cpu: {{ k8s_metrics_cpu_limit }}
              memory: {{ k8s_metrics_memory_limit }}
            requests:
              cpu: {{ k8s_metrics_cpu_request }}
              memory: {{ k8s_metrics_memory_request }}
          livenessProbe:
            failureThreshold: 3
            httpGet:
              path: /livez
              port: https
              scheme: HTTPS
            periodSeconds: 10
          readinessProbe:
            failureThreshold: 3
            httpGet:
              path: /readyz
              port: https
              scheme: HTTPS
            periodSeconds: 10
          securityContext:
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: true
            runAsNonRoot: true
            runAsUser: 1000
            seccompProfile:
              type: RuntimeDefault
          volumeMounts:
            - name: tmp-dir
              mountPath: /tmp
      volumes:
        - name: tmp-dir
          emptyDir: {}
---
apiVersion: v1
kind: Service
metadata:
  name: metrics-server
  namespace: kube-system
  labels:
    k8s-app: metrics-server
spec:
  selector:
    k8s-app: metrics-server
  ports:
    - name: https
      port: 443
      targetPort: https
      protocol: TCP
