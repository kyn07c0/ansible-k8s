global_defs {
    router_id haproxy_{{ inventory_hostname }}
    enable_script_security
    script_user root
}

vrrp_script haproxy_check {
    script "{{ haproxy_check_script }}"
    interval 2
    weight 2
}

vrrp_instance VI_1 {
    interface {{ interface_name }}
    virtual_router_id 101
    priority {{ 100 if inventory_hostname == 'lb1' else 90 }}
    state {{ 'MASTER' if inventory_hostname == 'lb1' else 'BACKUP' }}
    advert_int 2
    authentication {
        auth_type PASS
        auth_pass {{ keepalived_auth_pass }}
    }
    virtual_ipaddress {
        {{ virtual_ip }}
    }
    track_script {
        haproxy_check
    }
}
