[Unit]
Description=Kubernetes Scheduler
Documentation=https://github.com/kubernetes/kubernetes
After=kube-apiserver.service
Requires=kube-apiserver.service

[Service]
ExecStart={{ kube_scheduler_binary_dir}}/kube-scheduler \
  --bind-address=0.0.0.0 \
  --kubeconfig={{ kube_scheduler_kubeconfig_dir }}/kube-scheduler.kubeconfig \
  --leader-elect=true \
  --leader-elect-lease-duration=15s \
  --leader-elect-renew-deadline=10s \
  --leader-elect-retry-period=2s \
  --v=2 \
  --tls-cert-file={{ cert_dir }}/kube-scheduler.crt \
  --tls-private-key-file={{ cert_dir }}/kube-scheduler.key
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
