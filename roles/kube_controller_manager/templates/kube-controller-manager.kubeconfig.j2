apiVersion: v1
clusters:
- cluster:
    certificate-authority: {{ cert_dir }}/{{ ca_cert_file }}
    server: https://{{ fqdn }}:6443
  name: k8s
contexts:
- context:
    cluster: k8s
    user: system:kube-controller-manager
  name: default
current-context: default
users:
- name: system:kube-controller-manager
  user:
    client-certificate: {{ cert_dir }}/{{ kube_controller_manager_cert_file }}
    client-key: {{ cert_dir }}/{{ kube_controller_manager_key_file }}
